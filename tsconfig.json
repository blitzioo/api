{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",

    "target": "ES2023",

    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "lib": ["ES2023", "DOM", "DOM.Iterable"],

    "strict": true,
    "sourceMap": true,

    "esModuleInterop": true,
    "resolveJsonModule": true,

    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },

  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}